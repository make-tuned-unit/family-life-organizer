# Kinrows server environment — set these in your host's dashboard (production
# runs on Railway) or a local .env (.env* is gitignored).
# Only SESSION_SECRET is hard-required in production; everything else degrades gracefully.

# ── Core ─────────────────────────────────────────────────────────────────────
# REQUIRED in production (server exits without it). Generate: openssl rand -hex 64
SESSION_SECRET=
NODE_ENV=production
PORT=3456
# Server timezone for all date math (defaults to America/Halifax)
TZ=America/Halifax

# ── Database ─────────────────────────────────────────────────────────────────
# SQLite directory. In production (Railway) this should point at a mounted
# persistent volume so family.db survives redeploys. If unset, the DB falls back
# to a HOME-based path that is only durable if a volume is mounted there.
# Tests set this to temp dirs. (RENDER_DISK_PATH is legacy/unused — Render isn't
# used for this project.)
# FAMILY_DB_DIR=/data

# ── AI Concierge (optional — AI features cleanly disabled if unset) ──────────
ANTHROPIC_API_KEY=

# ── Auth / 2FA ───────────────────────────────────────────────────────────────
# 1 = email two-factor required on every login. Only enable once the 2FA-capable
# app build is installed AND RESEND_API_KEY is set (server fail-fasts otherwise).
AUTH_2FA_ENABLED=0
# Seconds a just-rotated device refresh token keeps working (lost-response tolerance).
AUTH_TOKEN_GRACE_SECONDS=60
# TEST ONLY — echoes OTP codes in responses. Server refuses to boot with this in prod.
# AUTH_2FA_ECHO_CODE=1

# ── Email (Resend) — 2FA codes + waitlist ────────────────────────────────────
RESEND_API_KEY=
WAITLIST_FROM=Kinrows <hello@kinrows.com>
WAITLIST_REPLY_TO=hello@kinrows.com
# Internal address notified on each waitlist signup (blank = off)
WAITLIST_NOTIFY=
SITE_URL=https://kinrows.com

# ── Apple Push (APNs) — push silently disabled unless all three key vars set ─
APNS_KEY_ID=
APNS_TEAM_ID=
# base64 of the .p8 key file contents
APNS_KEY_BASE64=
APNS_BUNDLE_ID=com.mylauft.kinrows
# development = sandbox APNs first (per-token fallback covers mixed installs)
APNS_ENV=production

# ── Subscriptions / admin ────────────────────────────────────────────────────
# Comma-separated user IDs allowed on /api/admin/* endpoints
ADMIN_USER_IDS=
# Demo/dev comps: 1 = everyone premium; or comma-separated usernames
# COMP_PREMIUM_ALL=1
# COMP_PREMIUM_USERNAMES=
# Override the StoreKit root CA (rarely needed; built-in Apple Root CA G3 default)
# APPLE_ROOT_CA_BASE64=
